# =============================================================================
# rs-broker Environment Configuration
# Copy this file to .env and configure for your environment
# =============================================================================

# =============================================================================
# Server Configuration
# =============================================================================

# Server mode: producer, consumer, or both
RS_BROKER_SERVER__MODE=both

# HTTP server host
RS_BROKER_SERVER__HOST=0.0.0.0

# HTTP server port
RS_BROKER_SERVER__HTTP_PORT=8080

# gRPC server port
RS_BROKER_SERVER__GRPC_PORT=50051

# Graceful shutdown timeout in seconds
RS_BROKER_SERVER__SHUTDOWN_TIMEOUT_SECS=30

# Request timeout in seconds
RS_BROKER_SERVER__REQUEST_TIMEOUT_SECS=30

# =============================================================================
# Database Configuration
# =============================================================================

# Database type: postgres or mysql
RS_BROKER_DATABASE__TYPE=postgres

# Database host
RS_BROKER_DATABASE__HOST=localhost

# Database port (5432 for PostgreSQL, 3306 for MariaDB)
RS_BROKER_DATABASE__PORT=5432

# Database username
RS_BROKER_DATABASE__USERNAME=rsbroker

# Database password (IMPORTANT: Change in production!)
RS_BROKER_DATABASE__PASSWORD=rsbroker_dev_password

# Database name
RS_BROKER_DATABASE__DATABASE=rsbroker

# Connection pool settings
RS_BROKER_DATABASE__MAX_CONNECTIONS=25
RS_BROKER_DATABASE__MIN_CONNECTIONS=5
RS_BROKER_DATABASE__CONNECT_TIMEOUT_SECS=30
RS_BROKER_DATABASE__IDLE_TIMEOUT_SECS=300
RS_BROKER_DATABASE__MAX_LIFETIME_SECS=1800

# Run migrations on startup
RS_BROKER_DATABASE__AUTO_MIGRATE=true

# =============================================================================
# Kafka Configuration
# =============================================================================

# Kafka broker addresses (comma-separated)
RS_BROKER_KAFKA__BROKERS=localhost:9092

# Consumer group ID
RS_BROKER_KAFKA__CONSUMER_GROUP_ID=rs-broker-consumer

# Client ID for logging
RS_BROKER_KAFKA__CLIENT_ID=rs-broker

# Security protocol: plaintext, ssl, sasl_plaintext, sasl_ssl
RS_BROKER_KAFKA__SECURITY_PROTOCOL=plaintext

# SASL mechanism: PLAIN, SCRAM-SHA-256, SCRAM-SHA-512
RS_BROKER_KAFKA__SASL_MECHANISM=PLAIN

# SASL credentials (if using SASL authentication)
# RS_BROKER_KAFKA__SASL_USERNAME=your_username
# RS_BROKER_KAFKA__SASL_PASSWORD=your_password

# SSL/TLS settings (if using SSL)
# RS_BROKER_KAFKA__SSL_CA_LOCATION=/path/to/ca.crt
# RS_BROKER_KAFKA__SSL_CERTIFICATE_LOCATION=/path/to/client.crt
# RS_BROKER_KAFKA__SSL_KEY_LOCATION=/path/to/client.key

# =============================================================================
# Kafka Producer Settings
# =============================================================================

# Message timeout in milliseconds
RS_BROKER_KAFKA__PRODUCER__MESSAGE_TIMEOUT_MS=30000

# Request timeout in milliseconds
RS_BROKER_KAFKA__PRODUCER__REQUEST_TIMEOUT_MS=30000

# Acks: 0, 1, or -1 (all)
RS_BROKER_KAFKA__PRODUCER__ACKS=-1

# Enable idempotent producer
RS_BROKER_KAFKA__PRODUCER__ENABLE_IDEMPOTENCE=true

# Compression type: none, gzip, snappy, lz4, zstd
RS_BROKER_KAFKA__PRODUCER__COMPRESSION_TYPE=snappy

# Batch size in bytes
RS_BROKER_KAFKA__PRODUCER__BATCH_SIZE=16384

# Linger time in milliseconds
RS_BROKER_KAFKA__PRODUCER__LINGER_MS=5

# =============================================================================
# Kafka Consumer Settings
# =============================================================================

# Enable auto-commit offsets
RS_BROKER_KAFKA__CONSUMER__ENABLE_AUTO_COMMIT=false

# Auto-commit interval in milliseconds
RS_BROKER_KAFKA__CONSUMER__AUTO_COMMIT_INTERVAL_MS=5000

# Session timeout in milliseconds
RS_BROKER_KAFKA__CONSUMER__SESSION_TIMEOUT_MS=30000

# Heartbeat interval in milliseconds
RS_BROKER_KAFKA__CONSUMER__HEARTBEAT_INTERVAL_MS=10000

# Max poll records
RS_BROKER_KAFKA__CONSUMER__MAX_POLL_RECORDS=500

# Auto offset reset: earliest, latest, none
RS_BROKER_KAFKA__CONSUMER__AUTO_OFFSET_RESET=latest

# Topics to subscribe (comma-separated)
RS_BROKER_KAFKA__CONSUMER__TOPICS=events,orders

# =============================================================================
# Retry Configuration
# =============================================================================

# Maximum retry attempts
RS_BROKER_RETRY__MAX_RETRIES=5

# Initial delay in milliseconds
RS_BROKER_RETRY__INITIAL_DELAY_MS=1000

# Multiplier for exponential backoff
RS_BROKER_RETRY__MULTIPLIER=2.0

# Maximum delay in milliseconds
RS_BROKER_RETRY__MAX_DELAY_MS=60000

# Jitter factor (0.0 to 1.0)
RS_BROKER_RETRY__JITTER_FACTOR=0.1

# Retry scheduler interval in seconds
RS_BROKER_RETRY__SCHEDULER_INTERVAL_SECS=5

# Maximum messages to process per schedule
RS_BROKER_RETRY__BATCH_SIZE=100

# =============================================================================
# Dead Letter Queue Configuration
# =============================================================================

# Enable Dead Letter Queue
RS_BROKER_DLQ__ENABLED=true

# DLQ topic suffix
RS_BROKER_DLQ__TOPIC_SUFFIX=.dlq

# Log DLQ messages
RS_BROKER_DLQ__LOG_MESSAGES=true

# =============================================================================
# Outbox Configuration
# =============================================================================

# Polling interval in milliseconds
RS_BROKER_OUTBOX__POLL_INTERVAL_MS=100

# Batch size for publishing
RS_BROKER_OUTBOX__BATCH_SIZE=100

# Maximum concurrent publishes
RS_BROKER_OUTBOX__MAX_CONCURRENT=10

# Message retention in days (for cleanup)
RS_BROKER_OUTBOX__RETENTION_DAYS=7

# =============================================================================
# Inbox Configuration
# =============================================================================

# Maximum concurrent deliveries
RS_BROKER_INBOX__MAX_CONCURRENT_DELIVERIES=10

# Delivery timeout in milliseconds
RS_BROKER_INBOX__DELIVERY_TIMEOUT_MS=30000

# Message retention in days (for cleanup)
RS_BROKER_INBOX__RETENTION_DAYS=7

# =============================================================================
# Subscriber Configuration
# =============================================================================

# Default delivery timeout in milliseconds
RS_BROKER_SUBSCRIBER__DEFAULT_TIMEOUT_MS=30000

# Default maximum retries
RS_BROKER_SUBSCRIBER__DEFAULT_MAX_RETRIES=3

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# Log format: json, pretty
RS_BROKER_LOGGING__FORMAT=pretty

# Include span traces
RS_BROKER_LOGGING__INCLUDE_SPANS=true

# =============================================================================
# Metrics Configuration
# =============================================================================

# Enable Prometheus metrics
RS_BROKER_METRICS__ENABLED=true

# Metrics endpoint path
RS_BROKER_METRICS__PATH=/metrics

# Prometheus port
RS_BROKER_METRICS__PORT=9090

# =============================================================================
# Tracing Configuration
# =============================================================================

# Enable distributed tracing
RS_BROKER_TRACING__ENABLED=false

# Service name
RS_BROKER_TRACING__SERVICE_NAME=rs-broker

# OTLP endpoint
RS_BROKER_TRACING__OTLP_ENDPOINT=http://localhost:4317

# Sample ratio (0.0 to 1.0)
RS_BROKER_TRACING__SAMPLE_RATIO=1.0

# =============================================================================
# Health Check Configuration
# =============================================================================

# Health check endpoint path
RS_BROKER_HEALTH__PATH=/health

# Enable liveness probe
RS_BROKER_HEALTH__LIVENESS_ENABLED=true

# Enable readiness probe
RS_BROKER_HEALTH__READINESS_ENABLED=true
